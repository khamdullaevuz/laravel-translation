{
    "name": "khamdullaevuz/laravel-translation",
    "description": "translation package",
    "keywords": [
        "khamdullaevuz",
        "laravel",
        "laravel-translation"
    ],
    "homepage": "https://github.com/khamdullaevuz/laravel-translation",
    "license": "MIT",
    "authors": [
        {
            "name": "khamdullaevuz",
            "email": "elbek.khamdullaev@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^7.4|^8.0|^8.1",
        "spatie/laravel-package-tools": "^1.14.0",
        "illuminate/support": "^7.0|^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "Khamdullaevuz\\LaravelTranslation\\": "src"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Khamdullaevuz\\LaravelTranslation\\LaravelTranslationServiceProvider"
            ],
            "aliases": {
                "Translatable": "Khamdullaevuz\\LaravelTranslation\\Facades\\Translatable"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}